  "publicApiSurface": [
    "POST /api/auth/login - Validate institutional ID",
    "GET /api/usuarios/:id - Get user information",
    "POST /api/registro-falla - Register access failure",
    "POST /api/admin/desbloquear - Unblock user",
    "GET /api/admin/dashboard - Dashboard statistics",
    "GET /api/admin/reportes/:tipo - Export reports",
    "POST /api/admin/carga-csv - Load bulk data",
    "sp_registrar_ingreso_sin_carnet() - Register failure stored procedure",
    "sp_desbloquear_usuario() - Unblock user stored procedure",
    "sp_obtener_usuario_completo() - Get complete user info",
    "sp_preparar_nuevo_semestre() - Prepare new semester"
  ]
